# PostgreSQL connection settings for hantang-web-backend
# Copy this file to config.secret.properties and fill in real values.

# Hostname or IP of the PostgreSQL server
db.postgre_host=127.0.0.1

# PostgreSQL port. Defaults to 5432 in code when omitted.
db.postgre_port=5432

# Database name
db.postgre_database=hantang

# Database user
db.postgre_user=postgres

# Database password
db.postgre_password=change-me
